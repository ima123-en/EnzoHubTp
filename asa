ThirdFloorPlatform.Anchored     = true
ThirdFloorPlatform.CanCollide   = false
ThirdFloorPlatform.Material     = Enum.Material.SmoothPlastic
ThirdFloorPlatform.Color        = Color3.fromRGB(255, 0, 0)
ThirdFloorPlatform.Transparency = 0.5
ThirdFloorPlatform.CFrame       = CFrame.new(0, -1000, 0)
ThirdFloorPlatform.Parent       = Workspace

local function isThirdFloor(brainPos)
	return brainPos and brainPos.Y > 20
end

local function updateThirdFloorPlatform()
	local sel = getPrioritySelected()
	if not sel then
		ThirdFloorPlatform.CFrame = CFrame.new(0, -1000, 0)
		ThirdFloorPlatform.CanCollide = false
		return
	end
	local brainPos = getBrainrotPosUnified(sel)
	if not brainPos or not isThirdFloor(brainPos) then
		ThirdFloorPlatform.CFrame = CFrame.new(0, -1000, 0)
		ThirdFloorPlatform.CanCollide = false
		return
	end
	local airPos = Vector3.new(brainPos.X, brainPos.Y - 7.5, brainPos.Z)
	ThirdFloorPlatform.Position   = airPos - Vector3.new(0, 4.5, 0)
	ThirdFloorPlatform.CanCollide = true
end

task.spawn(function()
	while ThirdFloorPlatform and ThirdFloorPlatform.Parent do
		pcall(updateThirdFloorPlatform)
		task.wait(0.1)
	end
end)

local lastYHeartbeat3
RunService.Heartbeat:Connect(function()
	local char = LP.Character
	local hrp  = char and char:FindFirstChild("HumanoidRootPart")
	if not hrp or not ThirdFloorPlatform then
		lastYHeartbeat3 = nil
		return
	end
	local currentY = hrp.Position.Y
	local topY     = ThirdFloorPlatform.Position.Y + ThirdFloorPlatform.Size.Y * 0.5
	if not lastYHeartbeat3 then
		lastYHeartbeat3 = currentY
		return
	end
	if currentY > lastYHeartbeat3 then
		if lastYHeartbeat3 < topY and currentY < topY + 5 then
			ThirdFloorPlatform.CanCollide = false
			task.delay(0.08, function()
				if ThirdFloorPlatform then
					ThirdFloorPlatform.CanCollide = true
				end
			end)
		end
	end
	lastYHeartbeat3 = currentY
end)

local function softStabilizeHumanoid(hum)
	if not hum then return end
	if hum.Health <= 0 then return end
	local s = hum:GetState()
	if s == Enum.HumanoidStateType.FallingDown
		or s == Enum.HumanoidStateType.Ragdoll
		or s == Enum.HumanoidStateType.PlatformStanding then
		hum:ChangeState(Enum.HumanoidStateType.Running)
	end
end

local function EquipToolLP(name)
	local char = LP.Character
	if not char then return nil end
	local hum = char:FindFirstChildOfClass("Humanoid")
	if not hum then return nil end
	local bp   = LP:FindFirstChild("Backpack")
	local tool = char:FindFirstChild(name) or (bp and bp:FindFirstChild(name))
	if tool then
		hum:UnequipTools()
		task.wait()
		hum:EquipTool(tool)
	end
	return tool
end

local function placeCloneOnly()
	local char = LP.Character
	if not char then return false end
	local hum = char:FindFirstChildOfClass("Humanoid")
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not hum or not hrp then return false end
	softStabilizeHumanoid(hum)
	vZeroLocal(hrp)
	local cloner = EquipToolLP("Quantum Cloner")
	if not cloner then return false end
	task.wait(0.015)
	pcall(function() cloner:Activate() end)
	local cloneName = tostring(LP.UserId) .. "_Clone"
	local clone
	local t0 = tick()
	while tick() - t0 < 1.5 do
		clone = Workspace:FindFirstChild(cloneName)
		if clone then break end
		task.wait(0.03)
	end
	return clone ~= nil
end

local function swapWithClone()
	local tf  = PlayerGui:FindFirstChild("ToolsFrames")
	local qcf = tf and tf:FindFirstChild("QuantumCloner")
	local btn = qcf and qcf:FindFirstChild("TeleportToClone")
	if not btn then return false end
	btn.Visible = true
	if typeof(firesignal) == "function" then
		local ok = pcall(function()
			firesignal(btn.MouseButton1Down)
			firesignal(btn.MouseButton1Click)
			firesignal(btn.MouseButton1Up)
		end)
		if not ok then return false end
	else
		local inset = GuiService:GetGuiInset()
		local pos   = btn.AbsolutePosition + btn.AbsoluteSize * 0.5
		VirtualInputManager:SendMouseButtonEvent(pos.X+inset.X, pos.Y+inset.Y, 0, true,  game, 1)
		task.wait(0.02)
		VirtualInputManager:SendMouseButtonEvent(pos.X+inset.X, pos.Y+inset.Y, 0, false, game, 1)
	end
	return true
end

local function doCloneUnified()
	if _G._UnifiedIsCloning then return false end
	_G._UnifiedIsCloning = true
	local success = false
	local ok = pcall(function()
		if not placeCloneOnly() then return end
		task.wait(0.05)
		if not swapWithClone() then return end
		success = true
	end)
	_G._UnifiedIsCloning = false
	return ok and success
end

local function performFinalFix(hrp, hum, destPos, facingDir)
	if not hrp or not hrp.Parent then return end
	local preStopDist = 1
	local dashDist    = 2
	local preStopPos = destPos - (facingDir.Unit * preStopDist)
	local arriveDist = 0.5
	local speed      = 150
	local flying     = true
	local conn
	conn = RunService.Heartbeat:Connect(function()
		if not hrp or not hrp.Parent then
			flying = false
			return
		end
		local diff = preStopPos - hrp.Position
		if diff.Magnitude < arriveDist then
			flying = false
			return
		end
		hrp.AssemblyLinearVelocity = diff.Unit * speed
	end)
	while flying do task.wait() end
	if conn then conn:Disconnect() end
	vZeroLocal(hrp)
	hrp.CFrame = CFrame.new(hrp.Position, hrp.Position + facingDir)
	task.wait(0.02)
	if hum then
		hum:ChangeState(Enum.HumanoidStateType.Jumping)
	end
	hrp.AssemblyLinearVelocity = Vector3.new(0, 55, 0)
	task.wait(0.08)
	local steps  = 12
	local startP = hrp.Position
	local targetP = startP + facingDir.Unit * dashDist
	local diff = targetP - startP
	for i = 1, steps do
		if not hrp or not hrp.Parent then break end
		local alpha = i / steps
		local nextP = startP + (diff * alpha)
		hrp.CFrame = CFrame.new(nextP, nextP + facingDir)
		vZeroLocal(hrp)
		task.wait(0.01)
	end
	hrp.CFrame = CFrame.new(targetP, targetP + facingDir)
	vZeroLocal(hrp)
end

local function finalSnap(hrp, targetPos)
	if not hrp or not hrp.Parent then return end
	local char = hrp.Parent
	local hum  = char and char:FindFirstChildOfClass("Humanoid")
	local cf   = hrp.CFrame
	local baseTarget = Vector3.new(targetPos.X, targetPos.Y + 0.5, targetPos.Z)
	vZeroLocal(hrp)
	hrp.CFrame = CFrame.new(baseTarget) * CFrame.fromMatrix(Vector3.new(), cf.RightVector, cf.UpVector, cf.LookVector)
	vZeroLocal(hrp)
	softStabilizeHumanoid(hum)
end

local function velWalkTo(hrp, targetPos, walkSpeed)
	if not hrp or not hrp.Parent then return end
	local char = hrp.Parent
	local hum  = char and char:FindFirstChildOfClass("Humanoid")
	local EPS = 0.5
	local maxDuration  = 10
	local startTime    = tick()
	local conn
	conn = RunService.Heartbeat:Connect(function()
		if not hrp or not hrp.Parent then
			if conn then conn:Disconnect() end
			return
		end
		local pos   = hrp.Position
		local goal  = Vector3.new(targetPos.X, pos.Y, targetPos.Z)
		local diff  = goal - pos
		local dist  = diff.Magnitude
		if dist < EPS or tick() - startTime > maxDuration then
			if conn then conn:Disconnect() end
			finalSnap(hrp, targetPos)
			return
		end
		local dir = diff.Unit
		hrp.AssemblyLinearVelocity = Vector3.new(dir.X, 0, dir.Z) * walkSpeed
		softStabilizeHumanoid(hum)
	end)
end

local function getFrontOfBrainrot(hrp, brainPos)
	local offsetDist = 3
	local look = hrp and hrp.CFrame.LookVector or Vector3.new(0,0,-1)
	local target = brainPos - look * offsetDist
	if hrp then
		target = Vector3.new(target.X, hrp.Position.Y, target.Z)
	else
		target = Vector3.new(target.X, brainPos.Y + 0.5, target.Z)
	end
	return target
end

local function quickDoubleTpToBrainrot(sel)
	local brainPos = getBrainrotPosUnified(sel)
	if not brainPos then return end
	for i = 1, 2 do
		local char = LP.Character
		local hrp  = char and char:FindFirstChild("HumanoidRootPart")
		local hum  = char and char:FindFirstChildOfClass("Humanoid")
		if not hrp then return end
		equipAnyCarpet()
		vZeroLocal(hrp)
		local pos = hrp.Position
		local adjusted = Vector3.new(brainPos.X, pos.Y, brainPos.Z)
		local cf = hrp.CFrame
		hrp.CFrame = CFrame.new(adjusted + Vector3.new(0,0.5,0)) * CFrame.fromMatrix(Vector3.new(), cf.RightVector, cf.UpVector, cf.LookVector)
		vZeroLocal(hrp)
		softStabilizeHumanoid(hum)
		task.wait(0.3)
	end
end

local function AfterClone_ThirdFloorAware(savedSel)
	local sel = savedSel
	if not sel then return end
	local brainPos = getBrainrotPosUnified(sel)
	if not brainPos then return end
	local char = LP.Character
	local hrp  = char and char:FindFirstChild("HumanoidRootPart")
	local hum  = char and char:FindFirstChildOfClass("Humanoid")
	if not hrp then return end
	equipAnyCarpet()
	vZeroLocal(hrp)
	softStabilizeHumanoid(hum)
	if isThirdFloor(brainPos) and ThirdFloorPlatform and ThirdFloorPlatform.CanCollide then
		local airPos = Vector3.new(brainPos.X, brainPos.Y - 7.5, brainPos.Z)
		local target = airPos + Vector3.new(0, 2.5, 0)
		local walkSpeed = Config.TpSettings.WalkToBrainrotSpd or 50
		local done = false
		local conn
		conn = RunService.Heartbeat:Connect(function()
			if not hrp or not hrp.Parent then
				if conn then conn:Disconnect() end
				return
			end
			local diff = target - hrp.Position
			local dist = diff.Magnitude
			if dist < 0.8 then
				done = true
				vZeroLocal(hrp)
				if conn then conn:Disconnect() end
				return
			end
			hrp.AssemblyLinearVelocity = diff.Unit * walkSpeed
			softStabilizeHumanoid(hum)
		end)
		local t0 = tick()
		local timeout = 6
		while not done and tick() - t0 < timeout do
			task.wait(0.05)
		end
		if conn then conn:Disconnect() end
		vZeroLocal(hrp)
		softStabilizeHumanoid(hum)
		return
	end
	local targetPos = getFrontOfBrainrot(hrp, brainPos)
	local walkSpeed = Config.TpSettings.WalkToBrainrotSpd or 50
	velWalkTo(hrp, targetPos, walkSpeed)
end

local function velocityTpToBrainrot(sel)
	if not sel then return end
	local brainPos = getBrainrotPosUnified(sel)
	if not brainPos then return end
	local char = LP.Character
	local hrp  = char and char:FindFirstChild("HumanoidRootPart")
	local hum  = char and char:FindFirstChildOfClass("Humanoid")
	if not hrp then return end
	equipAnyCarpet()
	local speed = Config.TpSettings.WalkToBrainrotSpd or 50
	local route = { hrp.Position, brainPos }
	local stop = velMoveThrough(hrp, route, speed)
	local t0  = tick()
	local timeout = 5
	while tick() - t0 < timeout do
		if not hrp or not hrp.Parent then break end
		if (hrp.Position - brainPos).Magnitude < 2 then break end
		softStabilizeHumanoid(hum)
		task.wait(0.03)
	end
	stop()
	finalSnap(hrp, brainPos)
end

local function instantVelocityTpToBrainrot(sel)
	if not sel then return end
	local brainPos = getBrainrotPosUnified(sel)
	if not brainPos then return end
	local char = LP.Character
	local hrp  = char and char:FindFirstChild("HumanoidRootPart")
	local hum  = char and char:FindFirstChildOfClass("Humanoid")
	if not hrp then return end
	equipAnyCarpet()
	vZeroLocal(hrp)
	local pos = hrp.Position
	local targetPos
	if isThirdFloor(brainPos) and ThirdFloorPlatform and ThirdFloorPlatform.Parent then
		local platformTopY = (brainPos.Y - 12) + (ThirdFloorPlatform.Size.Y * 0.5)
		targetPos = Vector3.new(
			ThirdFloorPlatform.Position.X,
			platformTopY + 3,
			ThirdFloorPlatform.Position.Z
		)
	else
		targetPos = Vector3.new(brainPos.X, pos.Y, brainPos.Z)
	end
	local cf = hrp.CFrame
	hrp.CFrame = CFrame.new(targetPos + Vector3.new(0,0.5,0)) 
		* CFrame.fromMatrix(Vector3.new(), cf.RightVector, cf.UpVector, cf.LookVector)
	vZeroLocal(hrp)
	softStabilizeHumanoid(hum)
end

