local function getPrioritySelected()
	local ok, g = pcall(getgenv)
	if ok and g and g.PrioritySystem and g.PrioritySystem.SelectedData then
		return g.PrioritySystem.SelectedData
	end
	local plots = Workspace:FindFirstChild("Plots")
	if not plots then return nil end
	local bestSel, bestGen = nil, -1
	for _, plot in ipairs(plots:GetChildren()) do
		local podiums = plot:FindFirstChild("AnimalPodiums")
		if podiums then
			for _, podium in ipairs(podiums:GetChildren()) do
				local animal = podium:FindFirstChild("Animal")
				if animal and animal:IsA("Model") then
					local name = animal.Name
					local gen = 0
					local okData, data = pcall(function() return AnimalsData[name] end)
					if okData and type(data) == "table" and data.Generation then
						gen = tonumber(tostring(data.Generation)) or 0
					end
					if gen > bestGen then
						bestGen = gen
						bestSel = { plot = plot.Name, slot = tonumber(podium.Name), petName = name }
					end
				end
			end
		end
	end
	return bestSel
end

