	if gpe then return end
	if waitingTpKey and input.UserInputType == Enum.UserInputType.Keyboard then
		waitingTpKey = false
		local name = input.KeyCode.Name
		if name and name ~= "Unknown" then
			Config.TpSettings.TpKey = name
			TpKeyCode = input.KeyCode
			TpKeyButton.Text = name
			TpKeyButton.TextColor3 = Color3.fromRGB(200, 200, 210)
			SaveConfig()
		else
			TpKeyButton.Text = Config.TpSettings.TpKey or "T"
			TpKeyButton.TextColor3 = Color3.fromRGB(200, 200, 210)
		end
		return
	end
	if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
	if input.KeyCode == TpKeyCode then
		doVelocityTP()
	end
end)

if Config.AutoTpOnLoad then
	task.spawn(function()
		local char = LP.Character or LP.CharacterAdded:Wait()
		char:WaitForChild("HumanoidRootPart", 5)
		char:WaitForChild("Humanoid", 5)
		task.wait(Config.TpSettings.TpJoinDelay or 0)
		local t0 = tick()
		while tick() - t0 < 3 do
			local selData = getPrioritySelected()
			local petPos  = selData and getBrainrotPosUnified(selData)
			if selData and petPos then
				doVelocityTP()
				break
			end
			task.wait(0.1)
		end
	end)
end
