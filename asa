local function doGrappleHookThenCarpetMove(destPos, facingDir)
	local char = LP.Character
	local hrp  = char and char:FindFirstChild("HumanoidRootPart")
	local hum  = char and char:FindFirstChildOfClass("Humanoid")
	if not hrp then return end
	softStabilizeHumanoid(hum)
	local origChoice = Config.ToolChoice
	if origChoice == "Grapple" then
		fireGrappleOnceMouseFree()
		task.wait(0.25)
		Config.ToolChoice = "Carpet"
	end
	equipSelectedTpTool()
	_G.VanishCarpetSpeed = Config.TpSettings.TpGrappleSpeed or 260
	vZeroLocal(hrp)
	local route = computeRoute(hrp.Position, destPos, facingDir)
	local stopMove = velMoveThrough(hrp, route, Config.TpSettings.TpGrappleSpeed or 260)
	local t0 = tick()
	local timeout = 8
	while tick() - t0 < timeout do
		if not hrp or not hrp.Parent then break end
		if (hrp.Position - destPos).Magnitude < 4 then
			break
		end
		softStabilizeHumanoid(hum)
		task.wait(0.02)
	end
	stopMove()
	performFinalFix(hrp, hum, destPos, facingDir)
	Config.ToolChoice = origChoice
	SaveConfig()
end

local isTeleporting = false
_G.TPStatus = "idle"

local function doVelocityTP()
	if isTeleporting then return end
	isTeleporting = true
	_G.TPStatus = "start"
	if not NetModule2 then pcall(loadNet) end
	local char = LP.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	local hum = char and char:FindFirstChildOfClass("Humanoid")
	if not hrp or not hum then _G.TPStatus = "no_char"; isTeleporting = false; return end
	vZeroLocal(hrp)
	softStabilizeHumanoid(hum)
	local selData = getPrioritySelected()
	if not selData then
		_G.TPStatus = "no_priority_selection"
		isTeleporting = false
		return
	end
	local savedSel = selData
	local petPos = getBrainrotPosUnified(selData)
	if not petPos then
		_G.TPStatus = "no_pet_position"
		isTeleporting = false
		return
	end
	local plotName = selData.plot
	local brainBaseName = getBaseForPlot(plotName, petPos)
	if not brainBaseName then
		_G.TPStatus = "no_matching_base"
		isTeleporting = false
		return
	end
	local bestEntry = getBestBasePointInBase(brainBaseName, petPos)
	if not bestEntry then
		_G.TPStatus = "no_point_in_base"
		isTeleporting = false
		return
	end
	local destPos   = bestEntry.pos
	local facingDir = bestEntry.look
	if (Config.ToolChoice or "Grapple") == "Grapple" then
		doGrappleHookThenCarpetMove(destPos, facingDir)
	else
		equipSelectedTpTool()
		_G.VanishCarpetSpeed = (Config.ToolChoice or "Grapple") == "Grapple"
			and (Config.TpSettings.TpGrappleSpeed or 260)
			or (Config.TpSettings.TpV2Speed or 160)
		vZeroLocal(hrp)
		softStabilizeHumanoid(hum)
		local speedOverride = _G.VanishCarpetSpeed
		local route = computeRoute(hrp.Position, destPos, facingDir)
		local stopMove = velMoveThrough(hrp, route, speedOverride)
		local t0 = tick()
		local timeout = 8
		while tick() - t0 < timeout do
			if not hrp or not hrp.Parent then break end
			if (hrp.Position - destPos).Magnitude < 4 then
				break
			end
			softStabilizeHumanoid(hum)
			task.wait(0.02)
		end
		stopMove()
		performFinalFix(hrp, hum, destPos, facingDir)
	end

	_G.TPStatus = "at_base_before_clone"

	local currentPos = hrp.Position
	if (currentPos - destPos).Magnitude > 10 then
		_G.TPStatus = "base_not_reached"
		isTeleporting = false
		return
	end

	local _ahrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
	local _ahum = LP.Character and LP.Character:FindFirstChildOfClass("Humanoid")
	if _ahrp and _ahrp.Parent then
		vZeroLocal(_ahrp)
		softStabilizeHumanoid(_ahum)
		pcall(function() _ahrp.Anchored = true end)
	end
	task.wait(Config.TpSettings.CloneDelay or 0.03)
	if _ahrp and _ahrp.Parent then pcall(function() _ahrp.Anchored = false end) end
	softStabilizeHumanoid(_ahum)

	local cloneOk = doCloneUnified()
	if cloneOk then
		local tpDelay = Config.TpSettings.TpWaitDelay or 0.5
		tpDelay = math.clamp(tpDelay, 0.1, 0.9)
		task.wait(tpDelay)
		local chr = LP.Character
		local cHrp = chr and chr:FindFirstChild("HumanoidRootPart")
		local cHum = chr and chr:FindFirstChildOfClass("Humanoid")
		if cHrp then vZeroLocal(cHrp) end
		softStabilizeHumanoid(cHum)
		equipAnyCarpet()
		local mode = (Config.TpSettings.TpToBrainrotMode or "Velocity")
		if mode == "Velocity" then
			instantVelocityTpToBrainrot(savedSel)
		elseif mode == "TP" then
			quickDoubleTpToBrainrot(savedSel)
		else
			AfterClone_ThirdFloorAware(savedSel)
		end
		_G.TPStatus = "done"
	else
		_G.TPStatus = "clone_failed"
	end

	isTeleporting = false
end

