local STRUCT = { ["structure base home"] = true, ["Wall"] = true, ["Floor"] = true, ["Roof"] = true }
local SKIP_NAME = {
	["DeliveryHitbox"]=true, ["StealHitbox"]=true, ["LaserHitbox"]=true,
	["AnimalTarget"]=true, ["Multiplier"]=true,  ["Laser"]=true, ["Hitbox"]=true,
	["Spawn"]=true, ["MainRoot"]=true, ["SecondFloor"]=true, ["ThirdFloor"]=true, ["Slope"]=true
}

local function blocks(inst)
	if not inst then return false end
	if SKIP_NAME[inst.Name] then return false end
	if inst.CanCollide then return true end
	if STRUCT[inst.Name] then return true end
	local s = inst.Size
	if s and math.max(s.X * s.Y, s.X * s.Z, s.Y * s.Z) > 150 then return true end
	return false
end

local function blockRay(origin, target)
	local rp = RaycastParams.new()
	rp.FilterType = Enum.RaycastFilterType.Exclude
	rp.IgnoreWater = true
	local skip = {}
	for _, pl in ipairs(Players:GetPlayers()) do
		if pl.Character then skip[#skip + 1] = pl.Character end
	end
	local o = origin
	for _ = 1, 16 do
		rp.FilterDescendantsInstances = skip
		local d = target - o
		if d.Magnitude < 0.05 then return nil end
		local res = Workspace:Raycast(o, d, rp)
		if not res then return nil end
		if blocks(res.Instance) then return res end
		skip[#skip + 1] = res.Instance
		o = res.Position + d.Unit * 0.3
	end
	return nil
end

local function clearLine(a, b) return blockRay(a, b) == nil end

local CLEARANCE = 6
local function clearWide(a, b)
	if not clearLine(a, b) then return false end
	local d = Vector3.new(b.X - a.X, 0, b.Z - a.Z)
	if d.Magnitude < 0.1 then return true end
	local p = Vector3.new(-d.Z, 0, d.X).Unit * CLEARANCE
	return clearLine(a + p, b + p) and clearLine(a - p, b - p)
end

local function computeRoute(fromPos, toPos, facingDir)
	if clearLine(fromPos, toPos) then
		return { toPos }
	end
	local entry = facingDir and (toPos - facingDir * 14) or toPos
	local groundFrom = Vector3.new(fromPos.X, fromPos.Y, fromPos.Z)
	local groundTo   = Vector3.new(entry.X, fromPos.Y, entry.Z)
	local path = PathfindingService:CreatePath({
		AgentRadius      = 6,
		AgentHeight      = 6,
		AgentCanJump     = true,
		AgentJumpHeight  = 12,
		AgentMaxSlope    = 45,
		Costs            = { Water = 100 },
	})
	local ok = pcall(function()
		path:ComputeAsync(groundFrom, groundTo)
	end)
	if not ok or path.Status ~= Enum.PathStatus.Success then
		return { entry + Vector3.new(0, 3, 0), toPos }
	end
	local waypoints = path:GetWaypoints()
	if #waypoints == 0 then
		return { entry + Vector3.new(0, 3, 0), toPos }
	end
	local FLOAT = 3
	local raw = {}
	table.insert(raw, fromPos + Vector3.new(0, FLOAT, 0))
	local lastAdded = waypoints[1].Position
	table.insert(raw, lastAdded + Vector3.new(0, FLOAT, 0))
	for i = 2, #waypoints do
		local pos = waypoints[i].Position
		if (pos - lastAdded).Magnitude >= 6 then
			table.insert(raw, pos + Vector3.new(0, FLOAT, 0))
			lastAdded = pos
		end
	end
	table.insert(raw, entry + Vector3.new(0, FLOAT, 0))
	table.insert(raw, toPos)
	if #raw <= 2 then
		return raw
	end
	local simplified = { raw[1] }
	local currentIndex = 1
	while currentIndex < #raw do
		local bestIndex = currentIndex + 1
		for i = #raw, currentIndex + 1, -1 do
			local a = simplified[#simplified]
			local b = raw[i]
			if clearWide(a, b) then
				bestIndex = i
				break
			end
		end
		table.insert(simplified, raw[bestIndex])
		currentIndex = bestIndex
	end
	for i = 1, #simplified do
		local p = simplified[i]
		simplified[i] = Vector3.new(p.X, p.Y, p.Z)
	end
	return simplified
end

local function velMoveThrough(hrp, waypoints, speedOverride)
	if not hrp or not hrp.Parent or #waypoints == 0 then
		return function() end
	end
	local wpIdx = 1
	local done = false
	local conn
	local function hardStop()
		if done then return end
		done = true
		if conn then conn:Disconnect() end
		if hrp and hrp.Parent then
			vZeroLocal(hrp)
		end
	end
	conn = RunService.Heartbeat:Connect(function()
		if not hrp or not hrp.Parent or done then
			hardStop()
			return
		end
		local target = waypoints[wpIdx]
		local diff = target - hrp.Position
		local mag = diff.Magnitude
		if mag < ARRIVE then
			wpIdx = wpIdx + 1
			if wpIdx > #waypoints then
				hardStop()
				return
			end
			target = waypoints[wpIdx]
			diff = target - hrp.Position
			mag = diff.Magnitude
		end
		if mag >= 0.1 then
			local dir = diff.Unit
			local spd = speedOverride or (_G.VanishCarpetSpeed or Config.TpSettings.TpV2Speed or 160)
			hrp.AssemblyLinearVelocity = dir * spd
		end
	end)
	return function()
		hardStop()
	end
end

local function estimatePathDistance(fromPos, toPos)
	local path = PathfindingService:CreatePath({
		AgentRadius = 6,
		AgentHeight = 6,
		AgentCanJump = true,
		AgentJumpHeight = 45,
		AgentMaxSlope = 45,
		Costs = { Water = 100 },
	})
	local ok = pcall(function()
		path:ComputeAsync(fromPos, toPos)
	end)
	if not ok or path.Status ~= Enum.PathStatus.Success then
		return (fromPos - toPos).Magnitude
	end
	local wps = path:GetWaypoints()
	if #wps < 2 then
		return (fromPos - toPos).Magnitude
	end
	local dist = 0
	local last = wps[1].Position
	for i = 2, #wps do
		local p = wps[i].Position
		dist = dist + (p - last).Magnitude
		last = p
	end
	return dist
end

local function getBaseForPlot(plotName, brainPos)
	if plotName and PLOT_TO_BASE[plotName] then
		return PLOT_TO_BASE[plotName]
	end
	local plots = Workspace:FindFirstChild("Plots")
	if not plots then return nil end
	local plot = plots:FindFirstChild(plotName)
	if not plot then return nil end
	local plotPos = plot:GetPivot().Position
	local bestName
	local minDist = math.huge
	for baseName, pts in pairs(BASE_POINTS) do
		local sumPos = Vector3.new(0, 0, 0)
		local count = 0
		for _, pt in ipairs(pts) do
			sumPos += pt.pos
			count += 1
		end
		if count > 0 then
			local center = sumPos / count
			local d = (center - plotPos).Magnitude
			if d < minDist then
				minDist = d
				bestName = baseName
			end
		end
	end
	if plotName and bestName then
		PLOT_TO_BASE[plotName] = bestName
	end
	return bestName
end

local function getBestBasePointInBase(brainBaseName, brainPos)
	local baseList = BASE_POINTS[brainBaseName]
	if not baseList then return nil end
	local char = LP.Character
	local hrp  = char and char:FindFirstChild("HumanoidRootPart")
	local playerPos = hrp and hrp.Position or brainPos
	local minHeightDiff = math.huge
	for _, entry in ipairs(baseList) do
		local diff = math.abs(entry.pos.Y - brainPos.Y)
		if diff < minHeightDiff then
			minHeightDiff = diff
		end
	end
	local candidates = {}
	for _, entry in ipairs(baseList) do
		if math.abs(entry.pos.Y - brainPos.Y) <= (minHeightDiff + 5) then
			table.insert(candidates, entry)
		end
	end
	if #candidates == 0 then
		candidates = baseList
	end
	local bestEntry
	local minTravelDist = math.huge
	for _, entry in ipairs(candidates) do
		local distToPlayer = (entry.pos - playerPos).Magnitude
		if distToPlayer < minTravelDist then
			minTravelDist = distToPlayer
			bestEntry = entry
		end
	end
	return bestEntry
end

